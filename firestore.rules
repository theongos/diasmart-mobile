rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // PROFILS UTILISATEURS
    // ============================================
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Sous-collection repas de l'utilisateur
      match /repas/{repasId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ============================================
    // PATIENTS
    // ============================================
    match /patients/{patientId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ============================================
    // GLYCEMIE / GLUCOSE
    // ============================================
    match /glucose/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ============================================
    // CONVERSATIONS (MESSAGERIE PATIENT-MEDECIN)
    // Seuls les participants peuvent lire/écrire
    // ============================================
    match /conversations/{conversationId} {
      allow read: if request.auth != null
                  && (resource.data.patientUid == request.auth.uid
                      || resource.data.medecinUid == request.auth.uid);
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && (resource.data.patientUid == request.auth.uid
                        || resource.data.medecinUid == request.auth.uid);

      match /messages/{messageId} {
        allow read: if request.auth != null
                    && (get(/databases/$(database)/documents/conversations/$(conversationId)).data.patientUid == request.auth.uid
                        || get(/databases/$(database)/documents/conversations/$(conversationId)).data.medecinUid == request.auth.uid);
        allow create: if request.auth != null
                      && (get(/databases/$(database)/documents/conversations/$(conversationId)).data.patientUid == request.auth.uid
                          || get(/databases/$(database)/documents/conversations/$(conversationId)).data.medecinUid == request.auth.uid);
      }
    }

    // ============================================
    // HISTORIQUE CHATBOT ROLLY (multi-sessions)
    // ============================================
    match /rolly_history/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /messages/{messageId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /conversations/{convId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        match /messages/{messageId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }
    }

    // ============================================
    // ACTIVITE PHYSIQUE / PODOMETRE
    // Propriétaire uniquement
    // ============================================
    match /activite/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /steps/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ============================================
    // VALIDATIONS ROLLY (MEDECIN-PATIENT-IA)
    // Seuls patient et médecin concernés
    // ============================================
    match /validations/{validationId} {
      allow read: if request.auth != null
                  && (resource.data.patientUid == request.auth.uid
                      || resource.data.medecinUid == request.auth.uid);
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && (resource.data.patientUid == request.auth.uid
                        || resource.data.medecinUid == request.auth.uid);
    }

    // ============================================
    // MEDICAMENTS
    // ============================================
    match /medicaments/{medId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ============================================
    // RENDEZ-VOUS
    // ============================================
    match /rendezvous/{rdvId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ============================================
    // JOURNAL DE BORD
    // ============================================
    match /journal/{entryId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ============================================
    // REPAS (top-level collection)
    // ============================================
    match /repas/{repasId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ============================================
    // CONSENTEMENTS / DATA SHARING
    // Seuls patient et médecin concernés
    // ============================================
    match /consents/{consentId} {
      allow read: if request.auth != null
                  && (resource.data.patientUid == request.auth.uid
                      || resource.data.medecinUid == request.auth.uid);
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && (resource.data.patientUid == request.auth.uid
                        || resource.data.medecinUid == request.auth.uid);
      allow delete: if request.auth != null
                    && resource.data.patientUid == request.auth.uid;
    }

    // ============================================
    // DATA SHARING (collection alternative)
    // ============================================
    match /data_sharing/{docId} {
      allow read: if request.auth != null
                  && (resource.data.patientUid == request.auth.uid
                      || resource.data.medecinUid == request.auth.uid);
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && (resource.data.patientUid == request.auth.uid
                        || resource.data.medecinUid == request.auth.uid);
      allow delete: if request.auth != null
                    && resource.data.patientUid == request.auth.uid;
    }

    // ============================================
    // BACKUPS (données privées par utilisateur)
    // ============================================
    match /backups/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ============================================
    // APPELS VoIP
    // Seuls appelant et appelé
    // ============================================
    match /calls/{callId} {
      allow read: if request.auth != null
                  && (resource.data.callerUid == request.auth.uid
                      || resource.data.calleeUid == request.auth.uid);
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && (resource.data.callerUid == request.auth.uid
                        || resource.data.calleeUid == request.auth.uid);

      match /iceCandidates/{iceId} {
        allow read, write: if request.auth != null
                          && (get(/databases/$(database)/documents/calls/$(callId)).data.callerUid == request.auth.uid
                              || get(/databases/$(database)/documents/calls/$(callId)).data.calleeUid == request.auth.uid);
      }
    }

    // ============================================
    // QUOTA (REQUETES IA PAR JOUR)
    // ============================================
    match /quota/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ============================================
    // CONFIG APPLICATION (MISES A JOUR)
    // ============================================
    match /app_config/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ============================================
    // COMMUNAUTE (messages publics entre patients)
    // ============================================
    match /community_messages/{msgId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.userId == request.auth.uid;
    }

    // ============================================
    // FCM TOKENS
    // ============================================
    match /fcm_tokens/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (resource == null || resource.data.uid == request.auth.uid);
    }
  }
}
