rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // PROFILS UTILISATEURS + SOUS-COLLECTIONS
    // ============================================
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;

      // Sous-collection repas (analyse de repas par patient)
      match /repas/{repasId} {
        allow read, write: if request.auth != null;
      }

      // Catch-all pour toute sous-collection future sous users
      match /{subcollection=**} {
        allow read, write: if request.auth != null;
      }
    }

    // ============================================
    // GLYCEMIE / GLUCOSE
    // ============================================
    match /glucose/{docId} {
      allow read, write: if request.auth != null;
    }

    // ============================================
    // CONVERSATIONS (MESSAGERIE PATIENT-MEDECIN)
    // ============================================
    match /conversations/{conversationId} {
      allow read, write: if request.auth != null;

      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }

      // Catch-all sous-collections conversations
      match /{subcollection=**} {
        allow read, write: if request.auth != null;
      }
    }

    // ============================================
    // HISTORIQUE CHATBOT ROLLY (multi-sessions)
    // ============================================
    match /rolly_history/{userId} {
      allow read, write: if request.auth != null;

      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }

      match /conversations/{convId} {
        allow read, write: if request.auth != null;

        match /messages/{messageId} {
          allow read, write: if request.auth != null;
        }
      }

      // Catch-all sous-collections rolly_history
      match /{subcollection=**} {
        allow read, write: if request.auth != null;
      }
    }

    // ============================================
    // VALIDATIONS ROLLY (MEDECIN-PATIENT-IA)
    // ============================================
    match /validations/{validationId} {
      allow read, write: if request.auth != null;
    }

    // ============================================
    // MEDICAMENTS
    // ============================================
    match /medicaments/{medId} {
      allow read, write: if request.auth != null;
    }

    // ============================================
    // RENDEZ-VOUS
    // ============================================
    match /rendezvous/{rdvId} {
      allow read, write: if request.auth != null;
    }

    // ============================================
    // JOURNAL DE BORD
    // ============================================
    match /journal/{entryId} {
      allow read, write: if request.auth != null;
    }

    // ============================================
    // REPAS (top-level collection)
    // ============================================
    match /repas/{repasId} {
      allow read, write: if request.auth != null;
    }

    // ============================================
    // CONSENTEMENTS / DATA SHARING
    // ============================================
    match /consents/{consentId} {
      allow read, write: if request.auth != null;
    }

    // ============================================
    // DATA SHARING (patient-medecin consent)
    // ============================================
    match /data_sharing/{docId} {
      allow read, write: if request.auth != null;
    }

    // ============================================
    // QUOTA (REQUETES IA PAR JOUR)
    // ============================================
    match /quota/{userId} {
      allow read, write: if request.auth != null;
    }

    // ============================================
    // CONFIG APP (mise a jour, versioning)
    // ============================================
    match /app_config/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ============================================
    // COMMUNAUTE PATIENTS
    // ============================================
    match /community_messages/{messageId} {
      allow read, write: if request.auth != null;
    }

    // ============================================
    // FCM TOKENS
    // ============================================
    match /fcm_tokens/{tokenId} {
      allow read, write: if request.auth != null;
    }

    // ============================================
    // CATCH-ALL : toute collection/sous-collection
    // non listee ci-dessus est autorisee pour les
    // utilisateurs authentifies. Cela garantit que
    // AUCUNE erreur "missing or insufficient
    // permissions" ne se produira pour un user connecte.
    // ============================================
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
